# Mixed intent triggers — query spans multiple domains
MIXED_TRIGGERS = [
    ("hadith", "quran"), ("fiqh", "quran"), ("fiqh", "hadith"),
    ("tafseer", "hadith"),
]


def detect_language(text: str) -> str:
    """
    Detect query language with English-first rule.
    If query STARTS with English words → always English regardless of
    pasted Arabic content inside.
    """
    stripped = text.strip()
    if not stripped:
        return "english"

    # Rule 1: starts with 2+ ASCII words → English
    first_words = stripped.split()[:5]
    ascii_word_count = sum(
        1 for w in first_words
        if len(w) > 1 and all(c.isascii() for c in w if c.isalpha())
    )
    if ascii_word_count >= 2:
        return "english"

    # Rule 2: dominant script
    arabic_chars     = len(re.findall(r'[\u0600-\u06FF]', stripped))
    devanagari_chars = len(re.findall(r'[\u0900-\u097F]', stripped))
    ascii_chars      = len(re.findall(r'[a-zA-Z]', stripped))
    total            = max(arabic_chars + devanagari_chars + ascii_chars, 1)

    if arabic_chars / total > 0.5:
        return "arabic"
    if devanagari_chars / total > 0.3:
        return "hindi"

    # Rule 3: Roman Urdu
    roman_urdu_words = [
        "kya","hai","hain","mein","ka","ki","ke","ap","aap","yeh","woh",
        "namaz","roza","dua","hadees","quran","allah","nabi","rasool",
        "bata","batao","dijiye","chahiye","karo","karna","batain",
        "jaiz","gunah","sawab","ibadat","masla","masail",
    ]
    words   = stripped.lower().split()
    ru_hits = sum(1 for w in words if w in roman_urdu_words)
    if ru_hits >= 2:
        return "roman_urdu"

    return "english"


def normalize_query(query: str) -> str:
    """Apply synonym normalization."""
    q = query.lower().strip()
    for src, tgt in SYNONYMS.items():
        q = q.replace(src, tgt)
    for arabic, english in ARABIC_SYNONYMS.items():
        q = q.replace(arabic, english)
    return q


def detect_intent(query: str) -> str:
    """Classify query into one of 8 intent types."""
    q = query.lower()

    # Smalltalk first
    for pattern in SMALLTALK_PATTERNS:
        if pattern in q:
            return INTENT_SMALLTALK

    # Score each intent
    scores = {intent: 0 for intent in INTENT_KEYWORDS}
    for intent, keywords in INTENT_KEYWORDS.items():
        for kw in keywords:
            if kw in q:
                scores[intent] += 1

    # Check for mixed intent
    top2 = sorted(scores.items(), key=lambda x: x[1], reverse=True)[:2]
    if top2[0][1] > 0 and top2[1][1] > 0:
        pair = tuple(sorted([top2[0][0], top2[1][0]]))
        if pair in MIXED_TRIGGERS:
            return INTENT_MIXED

    best = max(scores, key=scores.get)
    return best if scores[best] > 0 else INTENT_GENERAL


def expand_query(query: str, intent: str, lang: str) -> list:
    """
    Intelligent multi-variant query expansion for better retrieval recall.
    Returns up to 4 query variants.
    """
    normalized = normalize_query(query)
    q_lower    = query.lower()
    queries    = [query]

    if normalized != q_lower:
        queries.append(normalized)

    # Arabic expansion
    for arabic, english in ARABIC_SYNONYMS.items():
        if arabic in query:
            queries.append(f"{english} {normalized}")
            break

    # DUA: smart contextual expansion
    if intent == INTENT_DUA:
        for trigger, expansions in DUA_EXPANSIONS.items():
            if trigger in q_lower:
                queries.extend(expansions[:2])
                break
        if "hisnul" not in q_lower:
            queries.append(f"Hisnul Muslim {query}")

    # FIQH: add Arabic translation of key terms for better fiqh retrieval
    elif intent == INTENT_FIQH:
        for eng_term, arabic_terms in FIQH_ARABIC_MAP.items():
            if eng_term in q_lower:
                queries.append(f"{arabic_terms} {query}")
                break
        queries.append(f"Islamic ruling fiqh {query}")

    # HADITH: add narrator-style expansion
    elif intent == INTENT_HADITH:
        queries.append(f"narrated hadith {query}")

    # QURAN: add verse-style expansion
    elif intent == INTENT_QURAN:
        queries.append(f"Quran verse ayah surah {query}")

    # TAFSEER: add tafseer-style expansion
    elif intent == INTENT_TAFSEER:
        queries.append(f"tafseer ibn kathir explanation {query}")

    # MIXED: add both hadith and quran variants
    elif intent == INTENT_MIXED:
        queries.append(f"hadith {query}")
        queries.append(f"quran verse {query}")

    # Deduplicate preserving order
    seen, out = set(), []
    for q in queries:
        k = q.strip()
        if k and k not in seen:
            seen.add(k)
            out.append(k)
    return out[:4]


def get_fiqh_arabic_query(query: str) -> str:
    """For fiqh queries, generate Arabic equivalent for better fiqh DB retrieval."""
    q = query.lower()
    arabic_parts = []
    for eng, arabic in FIQH_ARABIC_MAP.items():
        if eng in q:
            arabic_parts.append(arabic)
    if arabic_parts:
        return " ".join(arabic_parts)
    return ""
